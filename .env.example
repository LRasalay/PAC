# Environment configuration

# Application
ENVIRONMENT=development
DEBUG=false

# Database
DATABASE_URL=sqlite+aiosqlite:///./policy.db
DATABASE_ECHO=false

# For PostgreSQL:
# DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/policy

# API
API_PREFIX=/api/v1
CORS_ORIGINS=["http://localhost:3000","http://localhost:8000"]

# Policy Configuration
POLICIES_DIRECTORY=policies
POLICY_SCHEMA_PATH=policies/schemas/policy_schema.json

# Logging
LOG_LEVEL=INFO

# Security (optional)
REQUIRE_API_KEY=false
API_KEY_HEADER=X-API-Key
